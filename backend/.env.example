# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://zf45:changeme@localhost:5432/zf45

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=changeme_different_value_openssl_rand_hex_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Admin bootstrap (Q7) — seeded on first boot if admin_users table is empty
# Generate hash: node -e "import('argon2').then(a=>a.default.hash('yourpassword',{type:2,memoryCost:65536,timeCost:3,parallelism:4}).then(console.log))"
ADMIN_EMAIL=admin@zoneforty5.tech
ADMIN_NAME=Janaka Sangeeth
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$changeme

# Resend (transactional email)
RESEND_API_KEY=re_changeme
EMAIL_FROM=noreply@zoneforty5.tech
EMAIL_TO=hello@zoneforty5.tech

# Cloudflare Turnstile (Q3) — 1x00000000000000000000AA is always-pass test secret
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Cloudflare R2 (image uploads)
R2_ACCOUNT_ID=changeme
R2_ACCESS_KEY_ID=changeme
R2_SECRET_ACCESS_KEY=changeme
R2_BUCKET=zf45-uploads
R2_PUBLIC_BASE=https://cdn.zoneforty5.tech
R2_ENDPOINT=https://changeme.r2.cloudflarestorage.com

# CORS — empty for production (same-origin), set for local dev
CORS_ORIGIN=http://localhost:5173
