# ──────────────────────────────────────────────────────────────────────────────
# ZoneForty5 — Environment Variables Reference
# Copy this file to .env (in the same directory as docker-compose.yml) and fill
# in real values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Docker image tag (set by CI/CD; default to 'latest' for manual deploys) ──
IMAGE_TAG=latest

# ── Node.js API ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by both the postgres service and the DATABASE_URL constructed in api service
POSTGRES_USER=zf45
POSTGRES_PASSWORD=changeme_use_openssl_rand_hex_32
POSTGRES_DB=zf45

# DATABASE_URL is assembled automatically in docker-compose.yml from the above.
# If you override it directly, it must match the postgres service credentials.
# DATABASE_URL=postgresql://zf45:<POSTGRES_PASSWORD>@postgres:5432/zf45

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_URL is set automatically in docker-compose.yml
# REDIS_URL=redis://redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=changeme_generate_with_openssl_rand_hex_32_different_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Admin bootstrap (Q7) ──────────────────────────────────────────────────────
# Seeded on first API boot. ADMIN_PASSWORD_HASH must be an argon2id-encoded string.
# Generate: node -e "import('argon2').then(a => a.default.hash('YourPassword', {
#   type: a.default.argon2id, memoryCost: 65536, timeCost: 3, parallelism: 4
# }).then(console.log))"
ADMIN_EMAIL=admin@zoneforty5.tech
ADMIN_NAME=Janaka Sangeeth
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$changeme

# ── Resend (transactional email) ──────────────────────────────────────────────
# API key from https://resend.com/api-keys — scope: Sending access
RESEND_API_KEY=re_changeme
EMAIL_FROM=noreply@zoneforty5.tech
# Cloudflare Email Routing forwards hello@ to founder Gmail
EMAIL_TO=hello@zoneforty5.tech

# ── Cloudflare Turnstile (bot protection — Q3) ────────────────────────────────
# Site key is PUBLIC — baked into the frontend build at build time.
# Used by the Frontend Agent as VITE_TURNSTILE_SITE_KEY.
TURNSTILE_SITE_KEY=changeme_from_cloudflare_dashboard
# Secret key is SERVER-SIDE only — never expose to the frontend.
TURNSTILE_SECRET=changeme_from_cloudflare_dashboard

# ── Cloudflare R2 (image uploads — Q5) ───────────────────────────────────────
# R2 credentials from Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=changeme_cloudflare_account_id
R2_ACCESS_KEY_ID=changeme_r2_access_key_id
R2_SECRET_ACCESS_KEY=changeme_r2_secret_access_key
R2_BUCKET=zf45-uploads
R2_PUBLIC_BASE=https://cdn.zoneforty5.tech
# R2 S3-compatible endpoint — replace <ACCOUNT_ID>
R2_ENDPOINT=https://changeme.r2.cloudflarestorage.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Leave empty in production (same-origin). Set to http://localhost:5173 for dev.
CORS_ORIGIN=

# ── Let's Encrypt / Certbot ───────────────────────────────────────────────────
# Email used for cert expiry notifications
CERTBOT_EMAIL=sangeeth.jdev@gmail.com
# Primary domain — must match your DNS A record
CERTBOT_DOMAIN=zoneforty5.tech

# ── GitHub Container Registry ─────────────────────────────────────────────────
# Used in deploy.yml GitHub Actions workflow. On EC2, use a PAT with
# read:packages scope or rely on GITHUB_TOKEN (available automatically in Actions).
GHCR_TOKEN=changeme_github_personal_access_token_with_read_packages

# ── AWS (S3 backup uploads) ───────────────────────────────────────────────────
# IAM user with s3:PutObject + s3:ListBucket on zf45-backups only.
# Used by the nightly backup script on the EC2 host (not a container).
AWS_ACCESS_KEY_ID=changeme_aws_iam_key_id
AWS_SECRET_ACCESS_KEY=changeme_aws_iam_secret
AWS_DEFAULT_REGION=ap-south-1
S3_BACKUP_BUCKET=zf45-backups
